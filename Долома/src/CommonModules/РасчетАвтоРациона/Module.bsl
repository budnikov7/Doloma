
// Модуль для автоматического расчета рационов
// Использует алгоритм оптимизации для подбора весов кормов

#Область ПрограммныйИнтерфейс

// Выполняет автоматический расчет рациона
//
// Параметры:
//  ТаблицаКормов - ТаблицаЗначений - таблица с кормами и их ограничениями
//  ТаблицаПитательности - ТаблицаЗначений - таблица питательности кормов
//  ТаблицаПоказателей - ТаблицаЗначений - таблица нормативных показателей
//  Дата - Дата - дата расчета
//
// Возвращаемое значение:
//  Структура - результат расчета:
//    * Успех - Булево - True если расчет успешен
//    * Сообщение - Строка - сообщение об ошибке или предупреждение
//    * РассчитанныеВеса - Соответствие - веса кормов (Номенклатура -> Вес)
//    * КрасныеПоказатели - Массив - показатели, выходящие за пределы нормы
//
Функция РассчитатьАвтоРацион(ТаблицаКормов, ТаблицаПитательности, ТаблицаПоказателей, Дата) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("РассчитанныеВеса", Новый Соответствие);
	Результат.Вставить("КрасныеПоказатели", Новый Массив);
	
	// Проверяем корректность входных данных
	Если ТаблицаКормов.Количество() = 0 Тогда
		Результат.Сообщение = "Не заданы корма для расчета";
		Возврат Результат;
	КонецЕсли;
	
	Если ТаблицаПоказателей.Количество() = 0 Тогда
		Результат.Сообщение = "Не заданы нормативные показатели";
		Возврат Результат;
	КонецЕсли;
	
	// Проверяем, что для всех кормов заданы ограничения
	Для Каждого СтрокаКорма Из ТаблицаКормов Цикл
		Если СтрокаКорма.МаксВес = 0 Тогда
			Результат.Сообщение = СтрШаблон("Для корма ""%1"" не задан максимальный вес", СтрокаКорма.Номенклатура);
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	
	// Используем улучшенный алгоритм оптимизации
	// Начинаем со средних значений диапазонов
	ИнициализироватьНачальныеВеса(ТаблицаКормов, Результат.РассчитанныеВеса);
	
	// Параметры оптимизации
	МаксимальноеКоличествоИтераций = 200; // Уменьшили количество итераций
	ТочностьСходимости = 0.05; // 5% - более реалистичная цель
	НачальныйШаг = 0.3; // 30% от диапазона - больше для быстрой сходимости
	МинимальныйШаг = 0.01; // 1% - минимальный шаг
	КоэффициентУменьшенияШага = 0.9; // Уменьшаем шаг постепенно
	
	ЛучшееРешение = Неопределено;
	ЛучшаяОценка = 999999;
	ШагОптимизации = НачальныйШаг;
	ИтерацийБезУлучшения = 0;
	
	// Итеративная оптимизация с адаптивным шагом
	Для Итерация = 1 По МаксимальноеКоличествоИтераций Цикл
		
		// Рассчитываем показатели для текущих весов
		ТекущиеПоказатели = РассчитатьПоказателиДляВесов(Результат.РассчитанныеВеса, ТаблицаПитательности, ТаблицаПоказателей);
		
		// Оцениваем качество решения
		ТекущаяОценка = ОценитьКачествоРешения(ТекущиеПоказатели, ТаблицаПоказателей);
		
		// Сохраняем лучшее решение
		Если ТекущаяОценка < ЛучшаяОценка Тогда
			УлучшениеОценки = ЛучшаяОценка - ТекущаяОценка;
			ЛучшаяОценка = ТекущаяОценка;
			ЛучшееРешение = СкопироватьСоответствие(Результат.РассчитанныеВеса);
			ИтерацийБезУлучшения = 0;
			
			// Если улучшение значительное, увеличиваем шаг
			Если УлучшениеОценки > 0.1 Тогда
				ШагОптимизации = Мин(ШагОптимизации * 1.2, НачальныйШаг);
			КонецЕсли;
		Иначе
			ИтерацийБезУлучшения = ИтерацийБезУлучшения + 1;
			
			// Если долго нет улучшений, уменьшаем шаг
			Если ИтерацийБезУлучшения > 10 Тогда
				ШагОптимизации = Макс(ШагОптимизации * КоэффициентУменьшенияШага, МинимальныйШаг);
				ИтерацийБезУлучшения = 0;
			КонецЕсли;
		КонецЕсли;
		
		// Проверяем условие останова
		Если ЛучшаяОценка < ТочностьСходимости Тогда
			Прервать;
		КонецЕсли;
		
		// Если шаг стал слишком маленьким и нет улучшений - выходим
		Если ШагОптимизации <= МинимальныйШаг И ИтерацийБезУлучшения > 5 Тогда
			Прервать;
		КонецЕсли;
		
		// Корректируем веса для улучшения решения
		КорректироватьВеса(Результат.РассчитанныеВеса, ТаблицаКормов, ТекущиеПоказатели, ТаблицаПоказателей, ШагОптимизации, ТаблицаПитательности);
		
	КонецЦикла;
	
	// Используем лучшее найденное решение
	Если ЛучшееРешение <> Неопределено Тогда
		Результат.РассчитанныеВеса = ЛучшееРешение;
	КонецЕсли;
	
	// Финальная проверка показателей
	ФинальныеПоказатели = РассчитатьПоказателиДляВесов(Результат.РассчитанныеВеса, ТаблицаПитательности, ТаблицаПоказателей);
	Результат.КрасныеПоказатели = НайтиКрасныеПоказатели(ФинальныеПоказатели, ТаблицаПоказателей);
	
	Если Результат.КрасныеПоказатели.Количество() = 0 Тогда
		Результат.Успех = Истина;
		Результат.Сообщение = "Рацион рассчитан успешно. Все показатели в норме.";
	Иначе
		Результат.Успех = Истина; // Решение найдено, но не идеальное
		Результат.Сообщение = СтрШаблон("Рацион рассчитан. Внимание: %1 показател(ей) выходят за пределы нормы.", 
			Результат.КрасныеПоказатели.Количество());
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ИнициализироватьНачальныеВеса(ТаблицаКормов, РассчитанныеВеса)
	
	Для Каждого СтрокаКорма Из ТаблицаКормов Цикл
		// Начинаем со среднего значения диапазона
		НачальныйВес = (СтрокаКорма.МинВес + СтрокаКорма.МаксВес) / 2;
		РассчитанныеВеса.Вставить(СтрокаКорма.Номенклатура, НачальныйВес);
	КонецЦикла;
	
КонецПроцедуры

Функция РассчитатьПоказателиДляВесов(РассчитанныеВеса, ТаблицаПитательности, ТаблицаПоказателей)
	
	ТекущиеПоказатели = Новый Соответствие;
	СуммаСВ = 0;
	
	// Инициализируем показатели нулями
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		ТекущиеПоказатели.Вставить(СтрокаПоказателя.ПоказательРациона, 0);
	КонецЦикла;
	
	// Суммируем вклад каждого корма
	Для Каждого ЭлементВеса Из РассчитанныеВеса Цикл
		Номенклатура = ЭлементВеса.Ключ;
		Вес = ЭлементВеса.Значение;
		
		// Находим питательность этого корма
		СтрокаПитательности = НайтиСтрокуПитательности(ТаблицаПитательности, Номенклатура);
		Если СтрокаПитательности = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Добавляем вклад корма в каждый показатель
		СухоеВещество = СтрокаПитательности.СухоеВещество * Вес / 1000;
		СуммаСВ = СуммаСВ + СухоеВещество;
		
		Для Каждого ЭлементПоказателя Из ТекущиеПоказатели Цикл
			ПоказательРациона = ЭлементПоказателя.Ключ;
			ИмяПоказателя = ПоказательРациона.ИмяПредопределенныхДанных;
			
			Если ИмяПоказателя = "СухоеВещество" Тогда
				ТекущиеПоказатели[ПоказательРациона] = ТекущиеПоказатели[ПоказательРациона] + СухоеВещество * 1000;
			ИначеЕсли ТаблицаПитательности.Колонки.Найти(ИмяПоказателя) <> Неопределено Тогда
				Попытка
					ЗначениеПитательности = СтрокаПитательности[ИмяПоказателя] * СухоеВещество;
					ТекущиеПоказатели[ПоказательРациона] = ТекущиеПоказатели[ПоказательРациона] + ЗначениеПитательности;
				Исключение
					// Колонка есть, но не удалось получить значение - пропускаем
				КонецПопытки;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Сохраняем сумму СВ для расчета процентных показателей
	ТекущиеПоказатели.Вставить("_СуммаСВ", СуммаСВ);
	
	Возврат ТекущиеПоказатели;
	
КонецФункции

Функция НайтиСтрокуПитательности(ТаблицаПитательности, Номенклатура)
	
	Для Каждого Строка Из ТаблицаПитательности Цикл
		Если Строка.Номенклатура = Номенклатура Тогда
			Возврат Строка;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция ОценитьКачествоРешения(ТекущиеПоказатели, ТаблицаПоказателей)
	
	СуммаОтклонений = 0;
	СуммаСВ = ТекущиеПоказатели["_СуммаСВ"];
	
	Если СуммаСВ = 0 Тогда
		Возврат 999999; // Некорректное решение
	КонецЕсли;
	
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		ПоказательРациона = СтрокаПоказателя.ПоказательРациона;
		
		Если ТекущиеПоказатели.Получить(ПоказательРациона) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееЗначение = ТекущиеПоказатели[ПоказательРациона];
		
		// Переводим в проценты если нужно
		Если СтрокаПоказателя.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.Процент Тогда
			ТекущееЗначение = 100 * ТекущееЗначение / СуммаСВ;
		КонецЕсли;
		
		// Вычисляем отклонение от нормы (только если есть ограничения)
		Отклонение = 0;
		
		Если ЗначениеЗаполнено(СтрокаПоказателя.Минимум) И ТекущееЗначение < СтрокаПоказателя.Минимум Тогда
			// Относительное отклонение
			Отклонение = (СтрокаПоказателя.Минимум - ТекущееЗначение) / Макс(Abs(СтрокаПоказателя.Минимум), 0.001);
			СуммаОтклонений = СуммаОтклонений + Отклонение * Отклонение;
		ИначеЕсли ЗначениеЗаполнено(СтрокаПоказателя.Максимум) И ТекущееЗначение > СтрокаПоказателя.Максимум Тогда
			// Относительное отклонение
			Отклонение = (ТекущееЗначение - СтрокаПоказателя.Максимум) / Макс(Abs(СтрокаПоказателя.Максимум), 0.001);
			СуммаОтклонений = СуммаОтклонений + Отклонение * Отклонение;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СуммаОтклонений;
	
КонецФункции

Процедура КорректироватьВеса(РассчитанныеВеса, ТаблицаКормов, ТекущиеПоказатели, ТаблицаПоказателей, ШагОптимизации, ТаблицаПитательности)
	
	// Умный градиентный спуск с анализом градиента
	ТекущаяОценка = ОценитьКачествоРешения(ТекущиеПоказатели, ТаблицаПоказателей);
	
	// Определяем, какие показатели нужно улучшить
	ПроблемныеПоказатели = НайтиПроблемныеПоказатели(ТекущиеПоказатели, ТаблицаПоказателей);
	
	// Если проблемных показателей нет - выходим
	Если ПроблемныеПоказатели.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЛучшееЛокальноеРешение = Неопределено;
	ЛучшаяЛокальнаяОценка = ТекущаяОценка;
	
	// Пробуем изменить веса кормов
	Для Каждого СтрокаКорма Из ТаблицаКормов Цикл
		Номенклатура = СтрокаКорма.Номенклатура;
		ТекущийВес = РассчитанныеВеса[Номенклатура];
		Диапазон = СтрокаКорма.МаксВес - СтрокаКорма.МинВес;
		
		Если Диапазон = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Шаг = Диапазон * ШагОптимизации;
		
		// Пробуем увеличить вес
		НовыйВес = Мин(ТекущийВес + Шаг, СтрокаКорма.МаксВес);
		Если НовыйВес <> ТекущийВес Тогда
			РассчитанныеВеса[Номенклатура] = НовыйВес;
			НовыеПоказатели = РассчитатьПоказателиДляВесов(РассчитанныеВеса, ТаблицаПитательности, ТаблицаПоказателей);
			НоваяОценка = ОценитьКачествоРешения(НовыеПоказатели, ТаблицаПоказателей);
			
			Если НоваяОценка < ЛучшаяЛокальнаяОценка Тогда
				ЛучшаяЛокальнаяОценка = НоваяОценка;
				ЛучшееЛокальноеРешение = СкопироватьСоответствие(РассчитанныеВеса);
			КонецЕсли;
			
			РассчитанныеВеса[Номенклатура] = ТекущийВес; // Возвращаем
		КонецЕсли;
		
		// Пробуем уменьшить вес
		НовыйВес = Макс(ТекущийВес - Шаг, СтрокаКорма.МинВес);
		Если НовыйВес <> ТекущийВес Тогда
			РассчитанныеВеса[Номенклатура] = НовыйВес;
			НовыеПоказатели = РассчитатьПоказателиДляВесов(РассчитанныеВеса, ТаблицаПитательности, ТаблицаПоказателей);
			НоваяОценка = ОценитьКачествоРешения(НовыеПоказатели, ТаблицаПоказателей);
			
			Если НоваяОценка < ЛучшаяЛокальнаяОценка Тогда
				ЛучшаяЛокальнаяОценка = НоваяОценка;
				ЛучшееЛокальноеРешение = СкопироватьСоответствие(РассчитанныеВеса);
			КонецЕсли;
			
			РассчитанныеВеса[Номенклатура] = ТекущийВес; // Возвращаем
		КонецЕсли;
	КонецЦикла;
	
	// Применяем лучшее найденное локальное решение
	Если ЛучшееЛокальноеРешение <> Неопределено Тогда
		Для Каждого Элемент Из ЛучшееЛокальноеРешение Цикл
			РассчитанныеВеса.Вставить(Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Функция НайтиПроблемныеПоказатели(ТекущиеПоказатели, ТаблицаПоказателей)
	
	ПроблемныеПоказатели = Новый Массив;
	СуммаСВ = ТекущиеПоказатели["_СуммаСВ"];
	
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		ПоказательРациона = СтрокаПоказателя.ПоказательРациона;
		
		Если ТекущиеПоказатели.Получить(ПоказательРациона) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееЗначение = ТекущиеПоказатели[ПоказательРациона];
		
		// Переводим в проценты если нужно
		Если СтрокаПоказателя.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.Процент И СуммаСВ > 0 Тогда
			ТекущееЗначение = 100 * ТекущееЗначение / СуммаСВ;
		КонецЕсли;
		
		// Проверяем выход за пределы нормы
		Если ЗначениеЗаполнено(СтрокаПоказателя.Минимум) И ТекущееЗначение < СтрокаПоказателя.Минимум Тогда
			ПроблемныеПоказатели.Добавить(ПоказательРациона);
		ИначеЕсли ЗначениеЗаполнено(СтрокаПоказателя.Максимум) И ТекущееЗначение > СтрокаПоказателя.Максимум Тогда
			ПроблемныеПоказатели.Добавить(ПоказательРациона);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПроблемныеПоказатели;
	
КонецФункции

Функция НайтиКрасныеПоказатели(ТекущиеПоказатели, ТаблицаПоказателей)
	
	КрасныеПоказатели = Новый Массив;
	СуммаСВ = ТекущиеПоказатели["_СуммаСВ"];
	
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		ПоказательРациона = СтрокаПоказателя.ПоказательРациона;
		
		Если НЕ ТекущиеПоказатели.Получить(ПоказательРациона) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееЗначение = ТекущиеПоказатели[ПоказательРациона];
		
		// Переводим в проценты если нужно
		Если СтрокаПоказателя.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.Процент И СуммаСВ > 0 Тогда
			ТекущееЗначение = 100 * ТекущееЗначение / СуммаСВ;
		КонецЕсли;
		
		// Проверяем выход за пределы нормы
		ВыходитЗаПределы = Ложь;
		
		Если ЗначениеЗаполнено(СтрокаПоказателя.Минимум) И ТекущееЗначение < СтрокаПоказателя.Минимум Тогда
			ВыходитЗаПределы = Истина;
		ИначеЕсли ЗначениеЗаполнено(СтрокаПоказателя.Максимум) И ТекущееЗначение > СтрокаПоказателя.Максимум Тогда
			ВыходитЗаПределы = Истина;
		КонецЕсли;
		
		Если ВыходитЗаПределы Тогда
			КрасныеПоказатели.Добавить(ПоказательРациона);
		КонецЕсли;
	КонецЦикла;
	
	Возврат КрасныеПоказатели;
	
КонецФункции

Функция СкопироватьСоответствие(Источник)
	
	Копия = Новый Соответствие;
	
	Для Каждого Элемент Из Источник Цикл
		Копия.Вставить(Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	
	Возврат Копия;
	
