
// Модуль для автоматического расчета рационов
// Использует продвинутые алгоритмы глобальной оптимизации:
// - Дифференциальная эволюция (DE) для глобального поиска
// - Симплекс-метод Нелдера-Мида для локальной оптимизации
// - Многостартовая стратегия для избежания локальных минимумов
// - Умная инициализация на основе анализа чувствительности

#Область ПрограммныйИнтерфейс

// Выполняет автоматический расчет рациона
//
// Параметры:
//  ТаблицаКормов - ТаблицаЗначений - таблица с кормами и их ограничениями
//  ТаблицаПитательности - ТаблицаЗначений - таблица питательности кормов
//  ТаблицаПоказателей - ТаблицаЗначений - таблица нормативных показателей
//  Дата - Дата - дата расчета
//
// Возвращаемое значение:
//  Структура - результат расчета:
//    * Успех - Булево - True если расчет успешен
//    * Сообщение - Строка - сообщение об ошибке или предупреждение
//    * РассчитанныеВеса - Соответствие - веса кормов (Номенклатура -> Вес)
//    * КрасныеПоказатели - Массив - показатели, выходящие за пределы нормы
//
Функция РассчитатьАвтоРацион(ТаблицаКормов, ТаблицаПитательности, ТаблицаПоказателей, Дата) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("РассчитанныеВеса", Новый Соответствие);
	Результат.Вставить("КрасныеПоказатели", Новый Массив);
	
	// Проверяем корректность входных данных
	Если ТаблицаКормов.Количество() = 0 Тогда
		Результат.Сообщение = "Не заданы корма для расчета";
		Возврат Результат;
	КонецЕсли;
	
	Если ТаблицаПоказателей.Количество() = 0 Тогда
		Результат.Сообщение = "Не заданы нормативные показатели";
		Возврат Результат;
	КонецЕсли;
	
	// Проверяем, что для всех кормов заданы ограничения
	Для Каждого СтрокаКорма Из ТаблицаКормов Цикл
		Если СтрокаКорма.МаксВес = 0 Тогда
			Результат.Сообщение = СтрШаблон("Для корма ""%1"" не задан максимальный вес", СтрокаКорма.Номенклатура);
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	
	// ========================================================================================
	// НОВЫЙ ПОДХОД: Гибридная глобально-локальная оптимизация
	// ========================================================================================
	
	// Подготавливаем контекст оптимизации
	КонтекстОптимизации = ПодготовитьКонтекстОптимизации(ТаблицаКормов, ТаблицаПитательности, ТаблицаПоказателей);
	
	ГлобальноеЛучшееРешение = Неопределено;
	ГлобальнаяЛучшаяОценка = 999999;
	
	// ========================================================================================
	// ШАГ 1: ДИФФЕРЕНЦИАЛЬНАЯ ЭВОЛЮЦИЯ (глобальный поиск)
	// ========================================================================================
	// Используем DE для нахождения области глобального оптимума
	РешениеDE = МетодДифференциальнойЭволюции(КонтекстОптимизации);
	
	Если РешениеDE.Оценка < ГлобальнаяЛучшаяОценка Тогда
		ГлобальнаяЛучшаяОценка = РешениеDE.Оценка;
		ГлобальноеЛучшееРешение = РешениеDE.Веса;
	КонецЕсли;
	
	// ========================================================================================
	// ШАГ 2: МНОГОСТАРТОВЫЙ СИМПЛЕКС-МЕТОД (локальная оптимизация)
	// ========================================================================================
	// Используем несколько начальных точек + лучшее решение DE
	
	// Старт 1: Результат дифференциальной эволюции
	РешениеСимплекс = СимплексМетодНелдераМида(КонтекстОптимизации, ГлобальноеЛучшееРешение);
	Если РешениеСимплекс.Оценка < ГлобальнаяЛучшаяОценка Тогда
		ГлобальнаяЛучшаяОценка = РешениеСимплекс.Оценка;
		ГлобальноеЛучшееРешение = РешениеСимплекс.Веса;
	КонецЕсли;
	
	// Старт 2: Умная инициализация (на основе анализа чувствительности)
	УмныеНачальныеВеса = УмнаяИнициализация(КонтекстОптимизации);
	РешениеСимплекс = СимплексМетодНелдераМида(КонтекстОптимизации, УмныеНачальныеВеса);
	Если РешениеСимплекс.Оценка < ГлобальнаяЛучшаяОценка Тогда
		ГлобальнаяЛучшаяОценка = РешениеСимплекс.Оценка;
		ГлобальноеЛучшееРешение = РешениеСимплекс.Веса;
	КонецЕсли;
	
	// Старт 3: Случайная инициализация для разнообразия
	СлучайныеВеса = СлучайнаяИнициализация(КонтекстОптимизации);
	РешениеСимплекс = СимплексМетодНелдераМида(КонтекстОптимизации, СлучайныеВеса);
	Если РешениеСимплекс.Оценка < ГлобальнаяЛучшаяОценка Тогда
		ГлобальнаяЛучшаяОценка = РешениеСимплекс.Оценка;
		ГлобальноеЛучшееРешение = РешениеСимплекс.Веса;
	КонецЕсли;
	
	// ========================================================================================
	// ШАГ 3: ФИНАЛЬНАЯ ПОЛИРОВКА (градиентная оптимизация)
	// ========================================================================================
	РешениеПолировка = ГрадиентнаяПолировка(КонтекстОптимизации, ГлобальноеЛучшееРешение);
	Если РешениеПолировка.Оценка < ГлобальнаяЛучшаяОценка Тогда
		ГлобальнаяЛучшаяОценка = РешениеПолировка.Оценка;
		ГлобальноеЛучшееРешение = РешениеПолировка.Веса;
	КонецЕсли;
	
	// ========================================================================================
	// ФОРМИРОВАНИЕ РЕЗУЛЬТАТА
	// ========================================================================================
	Результат.РассчитанныеВеса = ПреобразоватьМассивВСоответствие(ГлобальноеЛучшееРешение, КонтекстОптимизации.СписокКормов);
	
	// Финальная проверка показателей
	ФинальныеПоказатели = РассчитатьПоказателиДляВесов(Результат.РассчитанныеВеса, ТаблицаПитательности, ТаблицаПоказателей);
	Результат.КрасныеПоказатели = НайтиКрасныеПоказатели(ФинальныеПоказатели, ТаблицаПоказателей);
	
	Если Результат.КрасныеПоказатели.Количество() = 0 Тогда
		Результат.Успех = Истина;
		Результат.Сообщение = СтрШаблон("Рацион рассчитан успешно! Найдено оптимальное решение (оценка: %1).", Формат(ГлобальнаяЛучшаяОценка, "ЧДЦ=4"));
	ИначеЕсли ГлобальнаяЛучшаяОценка < 0.5 Тогда
		Результат.Успех = Истина;
		Результат.Сообщение = СтрШаблон("Рацион рассчитан с минимальными отклонениями. %1 показател(ей) незначительно выходят за пределы (оценка: %2).", 
			Результат.КрасныеПоказатели.Количество(), Формат(ГлобальнаяЛучшаяОценка, "ЧДЦ=4"));
	Иначе
		Результат.Успех = Истина;
		Результат.Сообщение = СтрШаблон("Рацион рассчитан. Внимание: %1 показател(ей) выходят за пределы нормы. Возможно, требования противоречивы или недостижимы с текущими кормами.", 
			Результат.КрасныеПоказатели.Количество());
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// ========================================================================================
// ПОДГОТОВКА КОНТЕКСТА ОПТИМИЗАЦИИ
// ========================================================================================

Функция ПодготовитьКонтекстОптимизации(ТаблицаКормов, ТаблицаПитательности, ТаблицаПоказателей)
	
	Контекст = Новый Структура;
	
	// Создаем индексированные списки для быстрого доступа
	Контекст.Вставить("ТаблицаКормов", ТаблицаКормов);
	Контекст.Вставить("ТаблицаПитательности", ТаблицаПитательности);
	Контекст.Вставить("ТаблицаПоказателей", ТаблицаПоказателей);
	
	// Создаем упорядоченный список кормов (для преобразования в вектор и обратно)
	СписокКормов = Новый Массив;
	МинимальныеВеса = Новый Массив;
	МаксимальныеВеса = Новый Массив;
	
	Для Каждого СтрокаКорма Из ТаблицаКормов Цикл
		СписокКормов.Добавить(СтрокаКорма.Номенклатура);
		МинимальныеВеса.Добавить(СтрокаКорма.МинВес);
		МаксимальныеВеса.Добавить(СтрокаКорма.МаксВес);
	КонецЦикла;
	
	Контекст.Вставить("СписокКормов", СписокКормов);
	Контекст.Вставить("МинимальныеВеса", МинимальныеВеса);
	Контекст.Вставить("МаксимальныеВеса", МаксимальныеВеса);
	Контекст.Вставить("Размерность", СписокКормов.Количество());
	
	// Индекс питательности для быстрого поиска
	ИндексПитательности = Новый Соответствие;
	Для Каждого СтрокаПитательности Из ТаблицаПитательности Цикл
		ИндексПитательности.Вставить(СтрокаПитательности.Номенклатура, СтрокаПитательности);
	КонецЦикла;
	Контекст.Вставить("ИндексПитательности", ИндексПитательности);
	
	Возврат Контекст;
	
КонецФункции

// ========================================================================================
// АЛГОРИТМ 1: ДИФФЕРЕНЦИАЛЬНАЯ ЭВОЛЮЦИЯ (DE)
// ========================================================================================

Функция МетодДифференциальнойЭволюции(Контекст)
	
	// Параметры DE
	РазмерПопуляции = Мин(50, Макс(20, Контекст.Размерность * 5)); // 5-10x размерности
	МаксИтераций = 100;
	F = 0.8; // Коэффициент мутации
	CR = 0.9; // Вероятность кроссовера
	ТочностьСходимости = 0.001;
	
	// Инициализируем популяцию (случайные решения)
	Популяция = Новый Массив;
	ОценкиПопуляции = Новый Массив;
	
	Для i = 1 По РазмерПопуляции Цикл
		Особь = СлучайнаяИнициализация(Контекст);
		Популяция.Добавить(Особь);
		Оценка = ОценитьВекторВесов(Особь, Контекст);
		ОценкиПопуляции.Добавить(Оценка);
	КонецЦикла;
	
	// Находим лучшую особь
	ЛучшийИндекс = 0;
	ЛучшаяОценка = ОценкиПопуляции[0];
	Для i = 1 По РазмерПопуляции - 1 Цикл
		Если ОценкиПопуляции[i] < ЛучшаяОценка Тогда
			ЛучшаяОценка = ОценкиПопуляции[i];
			ЛучшийИндекс = i;
		КонецЕсли;
	КонецЦикла;
	
	ПредыдущаяЛучшаяОценка = ЛучшаяОценка;
	ИтерацийБезУлучшения = 0;
	
	// Основной цикл эволюции
	Для НомерИтерации = 1 По МаксИтераций Цикл
		
		// Для каждой особи в популяции
		Для i = 0 По РазмерПопуляции - 1 Цикл
			
			// Выбираем три случайные различные особи (не совпадающие с текущей)
			r1 = СлучайноеЧисло(0, РазмерПопуляции - 1);
			Пока r1 = i Цикл
				r1 = СлучайноеЧисло(0, РазмерПопуляции - 1);
			КонецЦикла;
			
			r2 = СлучайноеЧисло(0, РазмерПопуляции - 1);
			Пока r2 = i ИЛИ r2 = r1 Цикл
				r2 = СлучайноеЧисло(0, РазмерПопуляции - 1);
			КонецЦикла;
			
			r3 = СлучайноеЧисло(0, РазмерПопуляции - 1);
			Пока r3 = i ИЛИ r3 = r1 ИЛИ r3 = r2 Цикл
				r3 = СлучайноеЧисло(0, РазмерПопуляции - 1);
			КонецЦикла;
			
			// Мутация: v = x_r1 + F * (x_r2 - x_r3)
			МутантныйВектор = Новый Массив;
			Для j = 0 По Контекст.Размерность - 1 Цикл
				Значение = Популяция[r1][j] + F * (Популяция[r2][j] - Популяция[r3][j]);
				// Обрезаем по границам
				Значение = ОграничитьЗначение(Значение, Контекст.МинимальныеВеса[j], Контекст.МаксимальныеВеса[j]);
				МутантныйВектор.Добавить(Значение);
			КонецЦикла;
			
			// Кроссовер
			ПробныйВектор = Новый Массив;
			jRand = СлучайноеЧисло(0, Контекст.Размерность - 1); // Гарантируем хотя бы один элемент от мутанта
			
			Для j = 0 По Контекст.Размерность - 1 Цикл
				Если СлучайноеЧисло() < CR ИЛИ j = jRand Тогда
					ПробныйВектор.Добавить(МутантныйВектор[j]);
				Иначе
					ПробныйВектор.Добавить(Популяция[i][j]);
				КонецЕсли;
			КонецЦикла;
			
			// Селекция: если пробный вектор лучше, заменяем
			ОценкаПробного = ОценитьВекторВесов(ПробныйВектор, Контекст);
			
			Если ОценкаПробного < ОценкиПопуляции[i] Тогда
				Популяция[i] = ПробныйВектор;
				ОценкиПопуляции[i] = ОценкаПробного;
				
				// Обновляем глобально лучшее
				Если ОценкаПробного < ЛучшаяОценка Тогда
					ЛучшаяОценка = ОценкаПробного;
					ЛучшийИндекс = i;
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
		// Проверяем сходимость
		РазницаОценок = ПредыдущаяЛучшаяОценка - ЛучшаяОценка;
		Если Макс(-РазницаОценок, РазницаОценок) < ТочностьСходимости Тогда
			ИтерацийБезУлучшения = ИтерацийБезУлучшения + 1;
			Если ИтерацийБезУлучшения >= 10 Тогда
				Прервать; // Сошлись
			КонецЕсли;
		Иначе
			ИтерацийБезУлучшения = 0;
		КонецЕсли;
		
		ПредыдущаяЛучшаяОценка = ЛучшаяОценка;
		
		// Ранний выход при отличном решении
		Если ЛучшаяОценка < 0.001 Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Структура("Веса, Оценка", Популяция[ЛучшийИндекс], ЛучшаяОценка);
	Возврат Результат;
	
КонецФункции

// ========================================================================================
// АЛГОРИТМ 2: СИМПЛЕКС-МЕТОД НЕЛДЕРА-МИДА
// ========================================================================================

Функция СимплексМетодНелдераМида(Контекст, НачальныйВектор)
	
	// Параметры алгоритма
	МаксИтераций = 200;
	ТочностьСходимости = 0.0001;
	Альфа = 1.0;  // Отражение
	Гамма = 2.0;  // Расширение
	Ро = 0.5;     // Сжатие
	Сигма = 0.5;  // Уменьшение
	
	n = Контекст.Размерность;
	
	// Создаем начальный симплекс (n+1 точка в n-мерном пространстве)
	Симплекс = Новый Массив;
	ОценкиСимплекса = Новый Массив;
	
	// Первая точка - начальный вектор
	Симплекс.Добавить(СкопироватьМассив(НачальныйВектор));
	ОценкиСимплекса.Добавить(ОценитьВекторВесов(НачальныйВектор, Контекст));
	
	// Остальные точки - возмущения начального вектора
	Для i = 0 По n - 1 Цикл
		НоваяТочка = СкопироватьМассив(НачальныйВектор);
		
		// Возмущаем i-ю координату
		Диапазон = Контекст.МаксимальныеВеса[i] - Контекст.МинимальныеВеса[i];
		Возмущение = Диапазон * 0.1; // 10% от диапазона
		
		НоваяТочка[i] = НоваяТочка[i] + Возмущение;
		НоваяТочка[i] = ОграничитьЗначение(НоваяТочка[i], Контекст.МинимальныеВеса[i], Контекст.МаксимальныеВеса[i]);
		
		Симплекс.Добавить(НоваяТочка);
		ОценкиСимплекса.Добавить(ОценитьВекторВесов(НоваяТочка, Контекст));
	КонецЦикла;
	
	// Основной цикл оптимизации
	Для НомерИтерации = 1 По МаксИтераций Цикл
		
		// Сортируем симплекс по оценкам (лучшая -> худшая)
		УпорядочитьСимплекс(Симплекс, ОценкиСимплекса);
		
		ЛучшаяОценка = ОценкиСимплекса[0];
		ХудшаяОценка = ОценкиСимплекса[n];
		
		// Проверяем сходимость
		РазницаОценок = ХудшаяОценка - ЛучшаяОценка;
		Если Макс(-РазницаОценок, РазницаОценок) < ТочностьСходимости Тогда
			Прервать;
		КонецЕсли;
		
		// Вычисляем центроид всех точек кроме худшей
		Центроид = ВычислитьЦентроид(Симплекс, n);
		
		// Отражение худшей точки относительно центроида
		ОтраженнаяТочка = ОтразитьТочку(Симплекс[n], Центроид, Альфа, Контекст);
		ОценкаОтраженной = ОценитьВекторВесов(ОтраженнаяТочка, Контекст);
		
		Если ОценкаОтраженной < ОценкиСимплекса[0] Тогда
			// Отраженная точка лучше лучшей - пробуем расширение
			РасширеннаяТочка = ОтразитьТочку(Симплекс[n], Центроид, Альфа * Гамма, Контекст);
			ОценкаРасширенной = ОценитьВекторВесов(РасширеннаяТочка, Контекст);
			
			Если ОценкаРасширенной < ОценкаОтраженной Тогда
				Симплекс[n] = РасширеннаяТочка;
				ОценкиСимплекса[n] = ОценкаРасширенной;
			Иначе
				Симплекс[n] = ОтраженнаяТочка;
				ОценкиСимплекса[n] = ОценкаОтраженной;
			КонецЕсли;
			
		ИначеЕсли ОценкаОтраженной < ОценкиСимплекса[n - 1] Тогда
			// Отраженная точка лучше второй худшей - принимаем
			Симплекс[n] = ОтраженнаяТочка;
			ОценкиСимплекса[n] = ОценкаОтраженной;
			
		Иначе
			// Сжатие
			Если ОценкаОтраженной < ОценкиСимплекса[n] Тогда
				// Внешнее сжатие
				СжатаяТочка = ОтразитьТочку(Симплекс[n], Центроид, Альфа * Ро, Контекст);
			Иначе
				// Внутреннее сжатие
				СжатаяТочка = ОтразитьТочку(Симплекс[n], Центроид, -Ро, Контекст);
			КонецЕсли;
			
			ОценкаСжатой = ОценитьВекторВесов(СжатаяТочка, Контекст);
			
			Если ОценкаСжатой < ОценкиСимплекса[n] Тогда
				Симплекс[n] = СжатаяТочка;
				ОценкиСимплекса[n] = ОценкаСжатой;
			Иначе
				// Уменьшение симплекса к лучшей точке
				Для i = 1 По n Цикл
					Симплекс[i] = УменьшитьКЛучшей(Симплекс[i], Симплекс[0], Сигма, Контекст);
					ОценкиСимплекса[i] = ОценитьВекторВесов(Симплекс[i], Контекст);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	// Возвращаем лучшую точку
	УпорядочитьСимплекс(Симплекс, ОценкиСимплекса);
	Результат = Новый Структура("Веса, Оценка", Симплекс[0], ОценкиСимплекса[0]);
	Возврат Результат;
	
КонецФункции

// ========================================================================================
// АЛГОРИТМ 3: ГРАДИЕНТНАЯ ПОЛИРОВКА (точная настройка)
// ========================================================================================

Функция ГрадиентнаяПолировка(Контекст, НачальныйВектор)
	
	МаксИтераций = 50;
	ТочностьСходимости = 0.00001;
	НачальныйШаг = 0.1;
	МинимальныйШаг = 0.001;
	КоэффициентУменьшенияШага = 0.8;
	
	ТекущийВектор = СкопироватьМассив(НачальныйВектор);
	ТекущаяОценка = ОценитьВекторВесов(ТекущийВектор, Контекст);
	ШагОптимизации = НачальныйШаг;
	
	Для НомерИтерации = 1 По МаксИтераций Цикл
		
		УлучшениеНайдено = Ложь;
		
		// Вычисляем градиент численно
		Градиент = ВычислитьЧисленныйГрадиент(ТекущийВектор, Контекст);
		
		// Нормализуем градиент
		НормаГрадиента = 0;
		Для i = 0 По Контекст.Размерность - 1 Цикл
			НормаГрадиента = НормаГрадиента + Градиент[i] * Градиент[i];
		КонецЦикла;
		НормаГрадиента = Sqrt(НормаГрадиента);
		
		Если НормаГрадиента < ТочностьСходимости Тогда
			Прервать; // Достигли стационарной точки
		КонецЕсли;
		
		// Пробуем шаг в направлении антиградиента
		НовыйВектор = Новый Массив;
		Для i = 0 По Контекст.Размерность - 1 Цикл
			Диапазон = Контекст.МаксимальныеВеса[i] - Контекст.МинимальныеВеса[i];
			Шаг = -Градиент[i] / НормаГрадиента * Диапазон * ШагОптимизации;
			НовоеЗначение = ТекущийВектор[i] + Шаг;
			НовоеЗначение = ОграничитьЗначение(НовоеЗначение, Контекст.МинимальныеВеса[i], Контекст.МаксимальныеВеса[i]);
			НовыйВектор.Добавить(НовоеЗначение);
		КонецЦикла;
		
		НоваяОценка = ОценитьВекторВесов(НовыйВектор, Контекст);
		
		Если НоваяОценка < ТекущаяОценка Тогда
			ТекущийВектор = НовыйВектор;
			ТекущаяОценка = НоваяОценка;
			УлучшениеНайдено = Истина;
		Иначе
			// Уменьшаем шаг
			ШагОптимизации = ШагОптимизации * КоэффициентУменьшенияШага;
		КонецЕсли;
		
		Если ШагОптимизации < МинимальныйШаг И НЕ УлучшениеНайдено Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Структура("Веса, Оценка", ТекущийВектор, ТекущаяОценка);
	Возврат Результат;
	
КонецФункции

// ========================================================================================
// УМНАЯ ИНИЦИАЛИЗАЦИЯ (на основе анализа чувствительности)
// ========================================================================================

Функция УмнаяИнициализация(Контекст)
	
	// Анализируем, какие корма наиболее важны для проблемных показателей
	// Начинаем с середины диапазонов, но корректируем на основе анализа
	
	Веса = Новый Массив;
	
	Для i = 0 По Контекст.Размерность - 1 Цикл
		// Начинаем ближе к максимуму для высокопитательных кормов
		// и ближе к минимуму для низкопитательных
		
		Номенклатура = Контекст.СписокКормов[i];
		СтрокаПитательности = Контекст.ИндексПитательности[Номенклатура];
		
		// Оцениваем питательную ценность
		ПитательнаяЦенность = 0;
		Попытка
			Если СтрокаПитательности <> Неопределено Тогда
				ПитательнаяЦенность = СтрокаПитательности.СухоеВещество;
			Иначе
				ПитательнаяЦенность = 0;
			КонецЕсли;
		Исключение
			// Игнорируем ошибки чтения питательности, используем значение по умолчанию
			ПитательнаяЦенность = 0;
		КонецПопытки;
		
		// Если корм питательный - ближе к максимуму, если нет - ближе к минимуму
		МинВес = Контекст.МинимальныеВеса[i];
		МаксВес = Контекст.МаксимальныеВеса[i];
		
		Если ПитательнаяЦенность > 300 Тогда // Высокая питательность
			Вес = МинВес + (МаксВес - МинВес) * 0.7; // 70% к максимуму
		ИначеЕсли ПитательнаяЦенность > 150 Тогда // Средняя питательность
			Вес = МинВес + (МаксВес - МинВес) * 0.5; // Середина
		Иначе // Низкая питательность
			Вес = МинВес + (МаксВес - МинВес) * 0.3; // 30% к максимуму
		КонецЕсли;
		
		Веса.Добавить(Вес);
	КонецЦикла;
	
	Возврат Веса;
	
КонецФункции

Функция СлучайнаяИнициализация(Контекст)
	
	Веса = Новый Массив;
	
	Для i = 0 По Контекст.Размерность - 1 Цикл
		МинВес = Контекст.МинимальныеВеса[i];
		МаксВес = Контекст.МаксимальныеВеса[i];
		Вес = МинВес + (МаксВес - МинВес) * СлучайноеЧисло();
		Веса.Добавить(Вес);
	КонецЦикла;
	
	Возврат Веса;
	
КонецФункции

// ========================================================================================
// ФУНКЦИИ ОЦЕНКИ РЕШЕНИЯ
// ========================================================================================

Функция ОценитьВекторВесов(ВекторВесов, Контекст)
	
	// Преобразуем вектор весов в соответствие
	СоответствиеВесов = ПреобразоватьМассивВСоответствие(ВекторВесов, Контекст.СписокКормов);
	
	// Рассчитываем показатели
	ТекущиеПоказатели = РассчитатьПоказателиДляВесов(СоответствиеВесов, Контекст.ТаблицаПитательности, Контекст.ТаблицаПоказателей);
	
	// Оцениваем качество
	Оценка = ОценитьКачествоРешения(ТекущиеПоказатели, Контекст.ТаблицаПоказателей);
	
	Возврат Оценка;
	
КонецФункции

Функция РассчитатьПоказателиДляВесов(РассчитанныеВеса, ТаблицаПитательности, ТаблицаПоказателей)
	
	ТекущиеПоказатели = Новый Соответствие;
	СуммаСВ = 0;
	
	// Инициализируем показатели нулями
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		ТекущиеПоказатели.Вставить(СтрокаПоказателя.ПоказательРациона, 0);
	КонецЦикла;
	
	// Суммируем вклад каждого корма
	Для Каждого ЭлементВеса Из РассчитанныеВеса Цикл
		Номенклатура = ЭлементВеса.Ключ;
		Вес = ЭлементВеса.Значение;
		
		// Находим питательность этого корма
		СтрокаПитательности = НайтиСтрокуПитательности(ТаблицаПитательности, Номенклатура);
		Если СтрокаПитательности = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Добавляем вклад корма в каждый показатель
		СухоеВещество = СтрокаПитательности.СухоеВещество * Вес / 1000;
		СуммаСВ = СуммаСВ + СухоеВещество;
		
		Для Каждого ЭлементПоказателя Из ТекущиеПоказатели Цикл
			ПоказательРациона = ЭлементПоказателя.Ключ;
			ИмяПоказателя = ПоказательРациона.ИмяПредопределенныхДанных;
			
			Если ИмяПоказателя = "СухоеВещество" Тогда
				ТекущиеПоказатели[ПоказательРациона] = ТекущиеПоказатели[ПоказательРациона] + СухоеВещество * 1000;
			ИначеЕсли ТаблицаПитательности.Колонки.Найти(ИмяПоказателя) <> Неопределено Тогда
				Попытка
					ЗначениеПитательности = СтрокаПитательности[ИмяПоказателя] * СухоеВещество;
					ТекущиеПоказатели[ПоказательРациона] = ТекущиеПоказатели[ПоказательРациона] + ЗначениеПитательности;
				Исключение
					// Колонка есть, но не удалось получить значение (например, неправильный тип) - пропускаем
					ЗначениеПитательности = 0;
				КонецПопытки;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Сохраняем сумму СВ для расчета процентных показателей
	ТекущиеПоказатели.Вставить("_СуммаСВ", СуммаСВ);
	
	Возврат ТекущиеПоказатели;
	
КонецФункции

Функция НайтиСтрокуПитательности(ТаблицаПитательности, Номенклатура)
	
	Для Каждого Строка Из ТаблицаПитательности Цикл
		Если Строка.Номенклатура = Номенклатура Тогда
			Возврат Строка;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция ОценитьКачествоРешения(ТекущиеПоказатели, ТаблицаПоказателей)
	
	СуммаОтклонений = 0;
	СуммаСВ = ТекущиеПоказатели["_СуммаСВ"];
	
	Если СуммаСВ = 0 Тогда
		Возврат 999999; // Некорректное решение
	КонецЕсли;
	
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		ПоказательРациона = СтрокаПоказателя.ПоказательРациона;
		
		Если ТекущиеПоказатели.Получить(ПоказательРациона) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееЗначение = ТекущиеПоказатели[ПоказательРациона];
		
		// Переводим в проценты если нужно
		Если СтрокаПоказателя.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.Процент Тогда
			ТекущееЗначение = 100 * ТекущееЗначение / СуммаСВ;
		КонецЕсли;
		
		// Вычисляем отклонение от нормы (только если есть ограничения)
		Отклонение = 0;
		
		Если ЗначениеЗаполнено(СтрокаПоказателя.Минимум) И ТекущееЗначение < СтрокаПоказателя.Минимум Тогда
			// Относительное отклонение
			Если СтрокаПоказателя.Минимум <> 0 Тогда
				Отклонение = (СтрокаПоказателя.Минимум - ТекущееЗначение) / СтрокаПоказателя.Минимум;
			Иначе
				Отклонение = СтрокаПоказателя.Минимум - ТекущееЗначение;
			КонецЕсли;
			СуммаОтклонений = СуммаОтклонений + Отклонение * Отклонение;
		ИначеЕсли ЗначениеЗаполнено(СтрокаПоказателя.Максимум) И ТекущееЗначение > СтрокаПоказателя.Максимум Тогда
			// Относительное отклонение
			Если СтрокаПоказателя.Максимум <> 0 Тогда
				Отклонение = (ТекущееЗначение - СтрокаПоказателя.Максимум) / СтрокаПоказателя.Максимум;
			Иначе
				Отклонение = ТекущееЗначение - СтрокаПоказателя.Максимум;
			КонецЕсли;
			СуммаОтклонений = СуммаОтклонений + Отклонение * Отклонение;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СуммаОтклонений;
	
КонецФункции

// ========================================================================================
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ДЛЯ СИМПЛЕКС-МЕТОДА
// ========================================================================================

Процедура УпорядочитьСимплекс(Симплекс, ОценкиСимплекса)
	
	// Пузырьковая сортировка (достаточна для небольших симплексов)
	n = Симплекс.Количество();
	
	Для i = 0 По n - 2 Цикл
		Для j = 0 По n - 2 - i Цикл
			Если ОценкиСимплекса[j] > ОценкиСимплекса[j + 1] Тогда
				// Меняем местами
				ВремТочка = Симплекс[j];
				Симплекс[j] = Симплекс[j + 1];
				Симплекс[j + 1] = ВремТочка;
				
				ВремОценка = ОценкиСимплекса[j];
				ОценкиСимплекса[j] = ОценкиСимплекса[j + 1];
				ОценкиСимплекса[j + 1] = ВремОценка;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ВычислитьЦентроид(Симплекс, БезПоследней)
	
	Центроид = Новый Массив;
	Размерность = Симплекс[0].Количество();
	
	// Инициализируем нулями
	Для i = 0 По Размерность - 1 Цикл
		Центроид.Добавить(0);
	КонецЦикла;
	
	// Суммируем все точки кроме последней (худшей)
	КоличествоТочек = Симплекс.Количество() - 1; // Не включаем последнюю
	
	Для i = 0 По КоличествоТочек - 1 Цикл
		Для j = 0 По Размерность - 1 Цикл
			Центроид[j] = Центроид[j] + Симплекс[i][j];
		КонецЦикла;
	КонецЦикла;
	
	// Делим на количество точек
	Для j = 0 По Размерность - 1 Цикл
		Центроид[j] = Центроид[j] / КоличествоТочек;
	КонецЦикла;
	
	Возврат Центроид;
	
КонецФункции

Функция ОтразитьТочку(ХудшаяТочка, Центроид, Коэффициент, Контекст)
	
	НоваяТочка = Новый Массив;
	Размерность = ХудшаяТочка.Количество();
	
	Для i = 0 По Размерность - 1 Цикл
		// Отражение: центроид + коэффициент * (центроид - худшая точка)
		Значение = Центроид[i] + Коэффициент * (Центроид[i] - ХудшаяТочка[i]);
		
		// Ограничиваем по границам
		Значение = ОграничитьЗначение(Значение, Контекст.МинимальныеВеса[i], Контекст.МаксимальныеВеса[i]);
		
		НоваяТочка.Добавить(Значение);
	КонецЦикла;
	
	Возврат НоваяТочка;
	
КонецФункции

Функция УменьшитьКЛучшей(Точка, ЛучшаяТочка, Коэффициент, Контекст)
	
	НоваяТочка = Новый Массив;
	Размерность = Точка.Количество();
	
	Для i = 0 По Размерность - 1 Цикл
		// Уменьшение к лучшей: лучшая + коэффициент * (точка - лучшая)
		Значение = ЛучшаяТочка[i] + Коэффициент * (Точка[i] - ЛучшаяТочка[i]);
		
		// Ограничиваем по границам
		Значение = ОграничитьЗначение(Значение, Контекст.МинимальныеВеса[i], Контекст.МаксимальныеВеса[i]);
		
		НоваяТочка.Добавить(Значение);
	КонецЦикла;
	
	Возврат НоваяТочка;
	
КонецФункции

// ========================================================================================
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ДЛЯ ГРАДИЕНТНОЙ ОПТИМИЗАЦИИ
// ========================================================================================

Функция ВычислитьЧисленныйГрадиент(Вектор, Контекст)
	
	Градиент = Новый Массив;
	Эпсилон = 0.001; // Малое приращение для численного дифференцирования
	ТекущаяОценка = ОценитьВекторВесов(Вектор, Контекст);
	
	Для i = 0 По Контекст.Размерность - 1 Цикл
		// Создаем вектор с малым приращением по i-й координате
		ВозмущенныйВектор = СкопироватьМассив(Вектор);
		
		Диапазон = Контекст.МаксимальныеВеса[i] - Контекст.МинимальныеВеса[i];
		Приращение = Диапазон * Эпсилон;
		
		ВозмущенныйВектор[i] = ВозмущенныйВектор[i] + Приращение;
		ВозмущенныйВектор[i] = ОграничитьЗначение(ВозмущенныйВектор[i], Контекст.МинимальныеВеса[i], Контекст.МаксимальныеВеса[i]);
		
		// Вычисляем частную производную
		ОценкаВозмущенной = ОценитьВекторВесов(ВозмущенныйВектор, Контекст);
		ЧастнаяПроизводная = (ОценкаВозмущенной - ТекущаяОценка) / Приращение;
		
		Градиент.Добавить(ЧастнаяПроизводная);
	КонецЦикла;
	
	Возврат Градиент;
	
КонецФункции

Функция НайтиКрасныеПоказатели(ТекущиеПоказатели, ТаблицаПоказателей)
	
	КрасныеПоказатели = Новый Массив;
	СуммаСВ = ТекущиеПоказатели["_СуммаСВ"];
	
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		ПоказательРациона = СтрокаПоказателя.ПоказательРациона;
		
		Если ТекущиеПоказатели.Получить(ПоказательРациона) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееЗначение = ТекущиеПоказатели[ПоказательРациона];
		
		// Переводим в проценты если нужно
		Если СтрокаПоказателя.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.Процент И СуммаСВ > 0 Тогда
			ТекущееЗначение = 100 * ТекущееЗначение / СуммаСВ;
		КонецЕсли;
		
		// Проверяем выход за пределы нормы
		ВыходитЗаПределы = Ложь;
		
		Если ЗначениеЗаполнено(СтрокаПоказателя.Минимум) И ТекущееЗначение < СтрокаПоказателя.Минимум Тогда
			ВыходитЗаПределы = Истина;
		ИначеЕсли ЗначениеЗаполнено(СтрокаПоказателя.Максимум) И ТекущееЗначение > СтрокаПоказателя.Максимум Тогда
			ВыходитЗаПределы = Истина;
		Иначе
			ВыходитЗаПределы = Ложь;
		КонецЕсли;
		
		Если ВыходитЗаПределы Тогда
			КрасныеПоказатели.Добавить(ПоказательРациона);
		КонецЕсли;
	КонецЦикла;
	
	Возврат КрасныеПоказатели;
	
КонецФункции

