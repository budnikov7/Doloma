Функция ПреобразоватьМассивВСоответствие(МассивВесов, СписокКормов)
	
	Соответствие = Новый Соответствие;
	
	Для i = 0 По СписокКормов.Количество() - 1 Цикл
		Соответствие.Вставить(СписокКормов[i], МассивВесов[i]);
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

Функция СкопироватьМассив(ИсходныйМассив)
	
	Копия = Новый Массив;
	
	Для Каждого Элемент Из ИсходныйМассив Цикл
		Копия.Добавить(Элемент);
	КонецЦикла;
	
	Возврат Копия;
	
КонецФункции

Функция ОграничитьЗначение(Значение, Минимум, Максимум)
	
	Если Значение < Минимум Тогда
		Возврат Минимум;
	ИначеЕсли Значение > Максимум Тогда
		Возврат Максимум;
	Иначе
		Возврат Значение;
	КонецЕсли;
	
КонецФункции

Функция СлучайноеЧисло(МинЗначение = 0, МаксЗначение = 1)
	
	// Если указан диапазон целых чисел, возвращаем целое
	Если МаксЗначение > МинЗначение И МаксЗначение - МинЗначение >= 1 Тогда
		Случайное = Новый ГенераторСлучайныхЧисел();
		Возврат Случайное.СлучайноеЧисло(МинЗначение, МаксЗначение);
	Иначе
		// Возвращаем случайное число от 0 до 1
		Случайное = Новый ГенераторСлучайныхЧисел();
		Возврат Случайное.СлучайноеЧисло() / 4294967296; // Максимальное значение генератора
	КонецЕсли;
	
КонецФункции

#КонецОбласти

