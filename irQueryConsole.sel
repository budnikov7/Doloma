		ЛЕВОЕ СОЕДИНЕНИЕ втСвернутая КАК втСвернутая
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Выбытия.СрезПоследних(&ДатаОкончания {(&ДатаОкончания)}, ) КАК ВыбытияСрезПоследних
			ПО втСвернутая.Животное = ВыбытияСрезПоследних.Животное
		ПО (втМесяцаОтчета.Месяц = НАЧАЛОПЕРИОДА(втСвернутая.ПлановаяДатаЗапуска, МЕСЯЦ)
				ИЛИ втМесяцаОтчета.Месяц = НАЧАЛОПЕРИОДА(втСвернутая.ПлановаяДатаОтёла, МЕСЯЦ)
				ИЛИ втМесяцаОтчета.Месяц = НАЧАЛОПЕРИОДА(втСвернутая.ДатаОтела, МЕСЯЦ)
				ИЛИ втМесяцаОтчета.Месяц = НАЧАЛОПЕРИОДА(втСвернутая.ДатаАборта, МЕСЯЦ)
				ИЛИ втМесяцаОтчета.Месяц = НАЧАЛОПЕРИОДА(втСвернутая.ДатаЗапуска, МЕСЯЦ)
				ИЛИ втМесяцаОтчета.Месяц = НАЧАЛОПЕРИОДА(ВыбытияСрезПоследних.Период, МЕСЯЦ))"},
