{"#",fc01b5df-97fe-449b-83d4-218a090e681e,75ca77fe-49a7-4df3-a559-c34c5211307c},
{"S","ВЫБРАТЬ
	aa.a * 1000 + bb.b * 100 + cc.c * 10 + dd.d КАК НомерДняИзДиапазона
ПОМЕСТИТЬ ВТ_Дни
ИЗ
	(ВЫБРАТЬ
		0 КАК a
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		1
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		2
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		3
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		4
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		5
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		6
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		7
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		8
	
	ОБЪЕДИНИТЬ
	
	ВЫБРАТЬ
		9) КАК aa
		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			0 КАК b
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			1
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			2
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			3
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			4
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			5
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			6
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			7
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			8
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			9) КАК bb
		ПО (ИСТИНА)
		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			0 КАК c
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			1
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			2
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			3
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			4
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			5
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			6
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			7
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			8
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			9) КАК cc
		ПО (ИСТИНА)
		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			0 КАК d
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			1
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			2
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			3
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			4
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			5
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			6
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			7
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			8
		
		ОБЪЕДИНИТЬ
		
		ВЫБРАТЬ
			9) КАК dd
		ПО (ИСТИНА)
ГДЕ
	aa.a * 1000 + bb.b * 100 + cc.c * 10 + dd.d <= РАЗНОСТЬДАТ(&ДатаНачала, &ДатаОкончания, ДЕНЬ)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ДатаНачала, ДЕНЬ, ВТ_Дни.НомерДняИзДиапазона), МЕСЯЦ) КАК Месяц,
	КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&ДатаНачала, ДЕНЬ, ВТ_Дни.НомерДняИзДиапазона), МЕСЯЦ) КАК КонецМесяца
ПОМЕСТИТЬ втМесяцаОтчета
ИЗ
	ВТ_Дни КАК ВТ_Дни
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВложенныйЗапрос.Животное КАК Животное,
	ВложенныйЗапрос.ДокументПланирования КАК ДокументПланирования,
	МАКСИМУМ(ВложенныйЗапрос.ПлановаяДатаЗапуска) КАК ПлановаяДатаЗапуска,
	МАКСИМУМ(ВложенныйЗапрос.ПлановаяДатаПереводаВСухостой) КАК ПлановаяДатаПереводаВСухостой,
	МАКСИМУМ(ВложенныйЗапрос.ПлановаяДатаОтёла) КАК ПлановаяДатаОтёла,
	NULL КАК ДатаОтела,
	NULL КАК ДокументОтела,
	NULL КАК ДатаЗапуска,
	NULL КАК ДокументЗапуска,
	NULL КАК ДатаАборта,
	NULL КАК ДокументАборта,
	NULL КАК ДатаПереводаВСухостой,
	NULL КАК ДокументПереводаВСухостой,
	ЕСТЬNULL(МАКСИМУМ(ВложенныйЗапрос.ПлановаяДатаЗапуска), МАКСИМУМ(ВложенныйЗапрос.ПлановаяДатаОтёла)) КАК ДатаСобытия,
	NULL КАК АбортСОткрытойЛактацией,
	ВложенныйЗапрос.ДатаПланирования КАК ДатаПланирования
ПОМЕСТИТЬ втВсеСобытия
ИЗ
	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		ДатаПредполагаемогоЗапуска.Животное КАК Животное,
		ДатаПредполагаемогоЗапуска.Регистратор КАК ДокументПланирования,
		ДатаПредполагаемогоЗапуска.ДатаЗапуска КАК ПлановаяДатаЗапуска,
		ДатаПредполагаемогоЗапуска.ДатаПереводаВоВторойСухостой КАК ПлановаяДатаПереводаВСухостой,
		NULL КАК ПлановаяДатаОтёла,
		НАЧАЛОПЕРИОДА(ДатаПредполагаемогоЗапуска.Период, ДЕНЬ) КАК ДатаПланирования
	ИЗ
		РегистрСведений.ДатаПредполагамогоЗапуска КАК ДатаПредполагаемогоЗапуска
	ГДЕ
		(ДатаПредполагаемогоЗапуска.ДатаЗапуска МЕЖДУ &ДатаНачала И &ДатаОкончания
				ИЛИ ДатаПредполагаемогоЗапуска.ДатаПереводаВоВторойСухостой МЕЖДУ &ДатаНачала И &ДатаОкончания)
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ РАЗЛИЧНЫЕ
		ДатыПланируемыхОтёлов.Животное,
		ДатыПланируемыхОтёлов.Регистратор,
		NULL,
		NULL,
		ДатыПланируемыхОтёлов.ДатаПредполагаемогоОтёла,
		НАЧАЛОПЕРИОДА(ДатыПланируемыхОтёлов.Период, ДЕНЬ)
	ИЗ
		РегистрСведений.ДатаПредполагаемогоОтёла КАК ДатыПланируемыхОтёлов
	ГДЕ
		ДатыПланируемыхОтёлов.ДатаПредполагаемогоОтёла МЕЖДУ &ДатаНачала И &ДатаОкончания) КАК ВложенныйЗапрос

СГРУППИРОВАТЬ ПО
	ВложенныйЗапрос.Животное,
	ВложенныйЗапрос.ДокументПланирования,
	ВложенныйЗапрос.ДатаПланирования

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	Отелы.Мать,
	NULL,
	NULL,
	NULL,
	NULL,
	НАЧАЛОПЕРИОДА(Отелы.Период, ДЕНЬ),
	Отелы.Регистратор,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	НАЧАЛОПЕРИОДА(Отелы.Период, ДЕНЬ),
	NULL,
	NULL
ИЗ
	РегистрСведений.Отелы КАК Отелы
ГДЕ
	Отелы.Период МЕЖДУ ДОБАВИТЬКДАТЕ(&ДатаНачала, ГОД, -1) И &ДатаОкончания

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	Аборты.Мать,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	НАЧАЛОПЕРИОДА(Аборты.Период, ДЕНЬ),
	Аборты.Регистратор,
	NULL,
	NULL,
	НАЧАЛОПЕРИОДА(Аборты.Период, ДЕНЬ),
	Аборты.ОткрытьЛактацию,
	NULL
ИЗ
	РегистрСведений.Аборты КАК Аборты
ГДЕ
	Аборты.Период МЕЖДУ ДОБАВИТЬКДАТЕ(&ДатаНачала, ГОД, -1) И &ДатаОкончания

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗапускЖивотных.Животное,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	ЗапускЖивотных.ДатаЗапуска,
	ЗапускЖивотных.Регистратор,
	NULL,
	NULL,
	NULL,
	NULL,
	ЗапускЖивотных.ДатаЗапуска,
	NULL,
	NULL
ИЗ
	РегистрСведений.ЗапускЖивотных КАК ЗапускЖивотных
ГДЕ
	ЗапускЖивотных.ДатаЗапуска МЕЖДУ ДОБАВИТЬКДАТЕ(&ДатаНачала, ГОД, -1) И &ДатаОкончания

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ПереводВСухостой2.Животное,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	НАЧАЛОПЕРИОДА(ПереводВСухостой2.Период, ДЕНЬ),
	ПереводВСухостой2.Регистратор,
	НАЧАЛОПЕРИОДА(ПереводВСухостой2.Период, ДЕНЬ),
	NULL,
	NULL
ИЗ
	РегистрСведений.РазмещениеЖивотных КАК ПереводВСухостой2
ГДЕ
	ПереводВСухостой2.Период МЕЖДУ ДОБАВИТЬКДАТЕ(&ДатаНачала, ГОД, -1) И &ДатаОкончания
	И ПереводВСухостой2.Корпус В
			(ВЫБРАТЬ РАЗЛИЧНЫЕ
				Фермы.КорпусДляСухостояНетелей КАК КорпусДляСухостояНетелей
			ИЗ
				Справочник.Фермы КАК Фермы
			ГДЕ
				Фермы.КорпусДляСухостояНетелей <> ЗНАЧЕНИЕ(Справочник.Корпуса.ПустаяСсылка)
				И Фермы.ПометкаУдаления = ЛОЖЬ)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	втВсеСобытия.Животное КАК Животное
ПОМЕСТИТЬ вт_Фильтр
ИЗ
	втВсеСобытия КАК втВсеСобытия
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	РазмещениеЖивотныхЗаполненное.Животное КАК Животное,
	РазмещениеЖивотныхЗаполненное.Ферма КАК Ферма
ПОМЕСТИТЬ вт_НачальноеРазмещение
ИЗ
	вт_Фильтр КАК вт_Фильтр
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеЖивотных.СрезПоследних(&ДатаНачала {(&ДатаНачала)}, Животное.Кличка <> ""Бык"") КАК РазмещениеЖивотныхЗаполненное
		ПО вт_Фильтр.Животное = РазмещениеЖивотныхЗаполненное.Животное
ГДЕ
	РазмещениеЖивотныхЗаполненное.Ферма <> ЗНАЧЕНИЕ(Справочник.Фермы.ПустаяСсылка)

СГРУППИРОВАТЬ ПО
	РазмещениеЖивотныхЗаполненное.Животное,
	РазмещениеЖивотныхЗаполненное.Ферма
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	вт_НачальноеРазмещение.Животное КАК Животное,
	вт_НачальноеРазмещение.Ферма КАК Ферма,
	&ДатаНачала КАК ДатаРазмещения
ПОМЕСТИТЬ вт_ВсеПеремещения
ИЗ
	вт_НачальноеРазмещение КАК вт_НачальноеРазмещение

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	РазмещениеЖивотных.Животное,
	РазмещениеЖивотных.Ферма,
	РазмещениеЖивотных.Период
ИЗ
	вт_Фильтр КАК вт_Фильтр
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеЖивотных КАК РазмещениеЖивотных
		ПО вт_Фильтр.Животное = РазмещениеЖивотных.Животное
ГДЕ
	РазмещениеЖивотных.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	И РазмещениеЖивотных.Ферма <> ЗНАЧЕНИЕ(Справочник.Фермы.ПустаяСсылка)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	вт_ВсеПеремещения.Животное КАК Животное,
	вт_ВсеПеремещения.Ферма КАК Ферма,
	вт_ВсеПеремещения.ДатаРазмещения КАК ДатаРазмещения,
	МИНИМУМ(вт_ВсеПеремещенияПосле.ДатаРазмещения) КАК ДатаСледующегоРазмещения
ПОМЕСТИТЬ вт_ДатыРазмещений
ИЗ
	вт_ВсеПеремещения КАК вт_ВсеПеремещения
		ЛЕВОЕ СОЕДИНЕНИЕ вт_ВсеПеремещения КАК вт_ВсеПеремещенияПосле
		ПО вт_ВсеПеремещения.Животное = вт_ВсеПеремещенияПосле.Животное
			И вт_ВсеПеремещения.ДатаРазмещения < вт_ВсеПеремещенияПосле.ДатаРазмещения

СГРУППИРОВАТЬ ПО
	вт_ВсеПеремещения.Животное,
	вт_ВсеПеремещения.Ферма,
	вт_ВсеПеремещения.ДатаРазмещения
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	вт_ДатыРазмещенийПосле.Животное КАК Животное,
	вт_ДатыРазмещенийПосле.Ферма КАК Ферма,
	вт_ДатыРазмещенийПосле.ДатаРазмещения КАК ДатаРазмещения
ПОМЕСТИТЬ вт_НовыеФермы
ИЗ
	вт_ДатыРазмещений КАК вт_ДатыРазмещений
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_ДатыРазмещений КАК вт_ДатыРазмещенийПосле
		ПО вт_ДатыРазмещений.Животное = вт_ДатыРазмещенийПосле.Животное
			И вт_ДатыРазмещений.ДатаСледующегоРазмещения = вт_ДатыРазмещенийПосле.ДатаРазмещения
ГДЕ
	вт_ДатыРазмещений.Ферма <> вт_ДатыРазмещенийПосле.Ферма
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	вт_НачальноеРазмещение.Животное КАК Животное,
	вт_НачальноеРазмещение.Ферма КАК Ферма,
	&ДатаНачала КАК ДатаРазмещения
ПОМЕСТИТЬ вт_ФиналРазмещения
ИЗ
	вт_НачальноеРазмещение КАК вт_НачальноеРазмещение

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	вт_НовыеФермы.Животное,
	вт_НовыеФермы.Ферма,
	вт_НовыеФермы.ДатаРазмещения
ИЗ
	вт_НовыеФермы КАК вт_НовыеФермы
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	вт_ФиналРазмещения.Животное КАК Животное,
	вт_ФиналРазмещения.Ферма КАК Ферма,
	вт_ФиналРазмещения.ДатаРазмещения КАК ДатаРазмещения,
	ЕСТЬNULL(МИНИМУМ(вт_ФиналРазмещенияДо.ДатаРазмещения), ДАТАВРЕМЯ(3000, 1, 1)) КАК ДатаДействияРазмещения
ПОМЕСТИТЬ вт_Размещения
ИЗ
	вт_ФиналРазмещения КАК вт_ФиналРазмещения
		ЛЕВОЕ СОЕДИНЕНИЕ вт_ФиналРазмещения КАК вт_ФиналРазмещенияДо
		ПО вт_ФиналРазмещения.Животное = вт_ФиналРазмещенияДо.Животное
			И вт_ФиналРазмещения.ДатаРазмещения < вт_ФиналРазмещенияДо.ДатаРазмещения

СГРУППИРОВАТЬ ПО
	вт_ФиналРазмещения.ДатаРазмещения,
	вт_ФиналРазмещения.Животное,
	вт_ФиналРазмещения.Ферма
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВложенныйЗапрос.Животное КАК Животное,
	ВложенныйЗапрос.Период КАК Период,
	Осеменения.Семя КАК Семя,
	Осеменения.Регистратор КАК Регистратор,
	ВложенныйЗапрос.ДатаСобытия КАК ДатаСобытия,
	ВложенныйЗапрос.ДатаПоследнегоАборта КАК ДатаПоследнегоАборта
ПОМЕСТИТЬ втОсеменения
ИЗ
	(ВЫБРАТЬ
		втВсеСобытия.Животное КАК Животное,
		МАКСИМУМ(Осеменения.Период) КАК Период,
		втВсеСобытия.ДатаСобытия КАК ДатаСобытия,
		МАКСИМУМ(Аборты.Период) КАК ДатаПоследнегоАборта
	ИЗ
		втВсеСобытия КАК втВсеСобытия
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Осеменения КАК Осеменения
			ПО втВсеСобытия.Животное = Осеменения.Животное
				И (ВЫБОР
					КОГДА втВсеСобытия.ДокументПланирования ССЫЛКА Документ.ДобавлениеЖивотного
						ТОГДА втВсеСобытия.ДатаСобытия
					ИНАЧЕ ЕСТЬNULL(втВсеСобытия.ДатаПланирования, втВсеСобытия.ДатаСобытия)
				КОНЕЦ > Осеменения.Период)
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Аборты КАК Аборты
			ПО (Аборты.Период МЕЖДУ втВсеСобытия.ДатаПланирования И втВсеСобытия.ДатаСобытия)
				И втВсеСобытия.Животное = Аборты.Мать
	
	СГРУППИРОВАТЬ ПО
		втВсеСобытия.Животное,
		втВсеСобытия.ДатаСобытия) КАК ВложенныйЗапрос
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Осеменения КАК Осеменения
		ПО ВложенныйЗапрос.Животное = Осеменения.Животное
			И ВложенныйЗапрос.Период = Осеменения.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втВсеСобытия.Животное КАК Животное,
	ЕСТЬNULL(втОсеменения.Период, втВсеСобытия.ДатаСобытия) КАК ДатаПервогоСобытия,
	МАКСИМУМ(ВЫБОР
			КОГДА ЕСТЬNULL(втОсеменения.Период, втВсеСобытия.ДатаСобытия) > ЕСТЬNULL(ДатыПервыхОтеловИВыбраковки.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1))
				ТОГДА втВсеСобытия.ПлановаяДатаЗапуска
			ИНАЧЕ втВсеСобытия.ПлановаяДатаПереводаВСухостой
		КОНЕЦ) КАК ПлановаяДатаЗапуска,
	МАКСИМУМ(втВсеСобытия.ПлановаяДатаОтёла) КАК ПлановаяДатаОтёла,
	МАКСИМУМ(втВсеСобытия.ДокументПланирования) КАК ДокументПланирования,
	МАКСИМУМ(втВсеСобытия.ДатаОтела) КАК ДатаОтела,
	МАКСИМУМ(втВсеСобытия.ДокументОтела) КАК ДокументОтела,
	МАКСИМУМ(ВЫБОР
			КОГДА втВсеСобытия.ДатаАборта ЕСТЬ NULL
				ТОГДА втОсеменения.ДатаПоследнегоАборта
			ИНАЧЕ втВсеСобытия.ДатаАборта
		КОНЕЦ) КАК ДатаАборта,
	МАКСИМУМ(втВсеСобытия.ДокументАборта) КАК ДокументАборта,
	втОсеменения.Период КАК ДатаОсеменения,
	втОсеменения.Семя КАК Семя,
	втОсеменения.Регистратор КАК ДокументОсеменения,
	МАКСИМУМ(ДатыПервыхОтеловИВыбраковки.ДатаВыбраковки) КАК ДатаВыбраковки,
	МАКСИМУМ(ДатыПервыхОтеловИВыбраковки.ДатаПервогоОтела) КАК ДатаПервогоОтела,
	МАКСИМУМ(ЕСТЬNULL(втВсеСобытия.ДатаЗапуска, втВсеСобытия.ДатаПереводаВСухостой)) КАК ДатаЗапуска,
	МАКСИМУМ(ЕСТЬNULL(втВсеСобытия.ДокументПереводаВСухостой, втВсеСобытия.ДокументЗапуска)) КАК ДокументЗапуска,
	МАКСИМУМ(втВсеСобытия.АбортСОткрытойЛактацией) КАК АбортСОткрытойЛактацией,
	ДатыПервыхОтеловИВыбраковки.КоличествоОтелов КАК КоличествоОтелов,
	МАКСИМУМ(втОсеменения.ДатаПоследнегоАборта) КАК ДатаПоследнегоАборта,
	МАКСИМУМ(втВсеСобытия.ДатаПланирования) КАК ДатаПланирования
ПОМЕСТИТЬ втСвернутая
ИЗ
	втВсеСобытия КАК втВсеСобытия
		ЛЕВОЕ СОЕДИНЕНИЕ втОсеменения КАК втОсеменения
		ПО втВсеСобытия.Животное = втОсеменения.Животное
			И втВсеСобытия.ДатаСобытия = втОсеменения.ДатаСобытия
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ВложенныйЗапрос.Животное КАК Животное,
			МИНИМУМ(ВложенныйЗапрос.ДатаВыбраковки) КАК ДатаВыбраковки,
			МИНИМУМ(ВложенныйЗапрос.ДатаПервогоОтела) КАК ДатаПервогоОтела,
			МАКСИМУМ(ВложенныйЗапрос.КоличествоОтелов) КАК КоличествоОтелов
		ИЗ
			(ВЫБРАТЬ
				ВыбраковкаЖивотныхСрезПоследних.Животное КАК Животное,
				ВыбраковкаЖивотныхСрезПоследних.Период КАК ДатаВыбраковки,
				NULL КАК ДатаПервогоОтела,
				NULL КАК КоличествоОтелов
			ИЗ
				РегистрСведений.ВыбраковкаЖивотных.СрезПоследних(&ДатаОкончания {(&ДатаОкончания)}, ) КАК ВыбраковкаЖивотныхСрезПоследних
			
			ОБЪЕДИНИТЬ ВСЕ
			
			ВЫБРАТЬ
				ВложенныйЗапрос.Мать,
				NULL,
				МИНИМУМ(ВложенныйЗапрос.Период),
				СУММА(ВложенныйЗапрос.КоличествоОтёлов)
			ИЗ
				(ВЫБРАТЬ
					МИНИМУМ(Отелы.Период) КАК Период,
					Отелы.Мать КАК Мать,
					КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВЫБОР
							КОГДА Отелы.Регистратор ССЫЛКА Документ.ДобавлениеЖивотного
								ТОГДА ДОБАВИТЬКДАТЕ(Отелы.Период, СЕКУНДА, Отелы.НомерСтроки)
							ИНАЧЕ Отелы.Регистратор
						КОНЕЦ) КАК КоличествоОтёлов
				ИЗ
					РегистрСведений.Отелы КАК Отелы
				ГДЕ
					Отелы.Период <= &ДатаОкончания
				{ГДЕ
					Отелы.Мать.* КАК Животное}
				
				СГРУППИРОВАТЬ ПО
					Отелы.Мать
				
				ОБЪЕДИНИТЬ ВСЕ
				
				ВЫБРАТЬ
					МАКСИМУМ(Аборты.Период),
					Аборты.Мать,
					СУММА(1)
				ИЗ
					РегистрСведений.Аборты КАК Аборты
				ГДЕ
					Аборты.Период <= &ДатаОкончания
					И Аборты.ОткрытьЛактацию = ИСТИНА
				{ГДЕ
					Аборты.Мать.* КАК Животное}
				
				СГРУППИРОВАТЬ ПО
					Аборты.Мать) КАК ВложенныйЗапрос
			
			СГРУППИРОВАТЬ ПО
				ВложенныйЗапрос.Мать
			
			ОБЪЕДИНИТЬ ВСЕ
			
			ВЫБРАТЬ
				АбортыСрезПоследних.Мать,
				NULL,
				АбортыСрезПоследних.Период,
				NULL
			ИЗ
				РегистрСведений.Аборты.СрезПоследних(&ДатаОкончания {(&ДатаОкончания)}, ОткрытьЛактацию = ИСТИНА {(Мать) КАК Животное}) КАК АбортыСрезПоследних) КАК ВложенныйЗапрос
		
		СГРУППИРОВАТЬ ПО
			ВложенныйЗапрос.Животное) КАК ДатыПервыхОтеловИВыбраковки
		ПО втВсеСобытия.Животное = ДатыПервыхОтеловИВыбраковки.Животное
ГДЕ
	ЕСТЬNULL(втВсеСобытия.ДатаЗапуска, ДАТАВРЕМЯ(3500, 1, 1)) > ЕСТЬNULL(ДатыПервыхОтеловИВыбраковки.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1))
	И ЕСТЬNULL(втВсеСобытия.ДатаПереводаВСухостой, ДАТАВРЕМЯ(1, 1, 1)) < ЕСТЬNULL(ДатыПервыхОтеловИВыбраковки.ДатаПервогоОтела, ДАТАВРЕМЯ(3500, 1, 1))

СГРУППИРОВАТЬ ПО
	втВсеСобытия.Животное,
	ЕСТЬNULL(втОсеменения.Период, втВсеСобытия.ДатаСобытия),
	втОсеменения.Период,
	втОсеменения.Семя,
	втОсеменения.Регистратор,
	ДатыПервыхОтеловИВыбраковки.КоличествоОтелов
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	вт_Размещения.Ферма КАК Ферма,
	вт_Размещения.ДатаРазмещения КАК ДатаРазмещения,
	вт_Размещения.ДатаДействияРазмещения КАК ДатаДействияРазмещения,
	втМесяцаОтчета.Месяц КАК Месяц,
	вт_Размещения.Животное КАК Животное
ПОМЕСТИТЬ вт_ПеремещенияПоПериодам
ИЗ
	втМесяцаОтчета КАК втМесяцаОтчета
		ЛЕВОЕ СОЕДИНЕНИЕ вт_Размещения КАК вт_Размещения
		ПО втМесяцаОтчета.Месяц < вт_Размещения.ДатаДействияРазмещения
			И втМесяцаОтчета.КонецМесяца >= вт_Размещения.ДатаРазмещения
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втСвернутая.Животное КАК Животное,
	втСвернутая.ДатаПервогоСобытия КАК ДатаПервогоСобытия,
	ЕСТЬNULL(втСвернутая.ПлановаяДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) КАК ПлановаяДатаЗапуска,
	ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)) КАК ПлановаяДатаОтёла,
	втСвернутая.ДокументПланирования КАК ДокументПланирования,
	ЕСТЬNULL(втСвернутая.ДатаОтела, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаОтела,
	втСвернутая.ДокументОтела КАК ДокументОтела,
	ЕСТЬNULL(втСвернутая.ДатаАборта, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаАборта,
	втСвернутая.ДокументАборта КАК ДокументАборта,
	ЕСТЬNULL(втСвернутая.ДатаОсеменения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаОсеменения,
	втСвернутая.Семя КАК Семя,
	втСвернутая.ДокументОсеменения КАК ДокументОсеменения,
	втСвернутая.ДатаВыбраковки КАК ДатаВыбраковки,
	ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПервогоОтела,
	ЕСТЬNULL(втСвернутая.ДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаЗапуска,
	втСвернутая.ДокументЗапуска КАК ДокументЗапуска,
	ЕСТЬNULL(ВыбытияСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаВыбытия,
	ВыбытияСрезПоследних.Регистратор КАК ДокументВыбытия,
	вт_ПеремещенияПоПериодам.Месяц КАК Месяц,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаОсеменения, втСвернутая.ПлановаяДатаЗапуска), МЕСЯЦ) < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И (НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) > НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) > 1)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ПланЗапускКорова, 
	
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаОсеменения, втСвернутая.ПлановаяДатаЗапуска), МЕСЯЦ) < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И (НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) = 1)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ПланЗапускТёлка,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаОсеменения, втСвернутая.ПлановаяДатаЗапуска), МЕСЯЦ) >= НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ПланЗапускБрак,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаОсеменения, втСвернутая.ПлановаяДатаОтёла), МЕСЯЦ) < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И (НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) > НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) > 1)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ПланОтёлКорова,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаОсеменения, втСвернутая.ПлановаяДатаОтёла), МЕСЯЦ) < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И (НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ НАЧАЛОПЕРИОДА(втСвернутая.ДатаПервогоСобытия, МЕСЯЦ) = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) = 1)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ПланОтёлТёлка,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаОсеменения, втСвернутая.ПлановаяДатаОтёла), МЕСЯЦ) >= НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ПланОтёлБрак,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И вт_ПеремещенияПоПериодам.Месяц < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И (вт_ПеремещенияПоПериодам.Месяц > НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ вт_ПеремещенияПоПериодам.Месяц = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) > 1)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЗапускКорова,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И вт_ПеремещенияПоПериодам.Месяц < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И (вт_ПеремещенияПоПериодам.Месяц < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ вт_ПеремещенияПоПериодам.Месяц = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) = 1)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЗапускТёлка,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаЗапуска, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И вт_ПеремещенияПоПериодам.Месяц >= НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЗапускБрак,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ДатаОтела, ЕСТЬNULL(втСвернутая.ДатаАборта, ДАТАВРЕМЯ(1, 1, 1))) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаОтела, ЕСТЬNULL(втСвернутая.ДатаАборта, ДАТАВРЕМЯ(1, 1, 1))), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И (втСвернутая.ДатаАборта ЕСТЬ NULL
