				И (вт_ПеремещенияПоПериодам.Месяц > НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ вт_ПеремещенияПоПериодам.Месяц = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) > 1)
				И втСвернутая.ДатаПланирования > ЕСТЬNULL(втСвернутая.ДатаПоследнегоАборта, ДАТАВРЕМЯ(1, 1, 1))
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ФактОтёлКорова,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И втСвернутая.ДатаОтела ЕСТЬ NULL
				И втСвернутая.ДатаАборта ЕСТЬ NULL
				И ВыбытияСрезПоследних.Период ЕСТЬ NULL
				И вт_ПеремещенияПоПериодам.Месяц < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И (вт_ПеремещенияПоПериодам.Месяц < НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					ИЛИ вт_ПеремещенияПоПериодам.Месяц = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
						И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) = 1)
				И втСвернутая.ДатаПланирования > ЕСТЬNULL(втСвернутая.ДатаПоследнегоАборта, ДАТАВРЕМЯ(1, 1, 1))
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ФактОтёлТёлка,
	ВЫБОР
		КОГДА ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)) Между вт_ПеремещенияПоПериодам.ДатаРазмещения И вт_ПеремещенияПоПериодам.ДатаДействияРазмещения
//		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ПлановаяДатаОтёла, ДАТАВРЕМЯ(1, 1, 1)), МЕСЯЦ) = вт_ПеремещенияПоПериодам.Месяц
				И втСвернутая.ДатаОтела ЕСТЬ NULL
				И втСвернутая.ДатаАборта ЕСТЬ NULL
				И ВыбытияСрезПоследних.Период ЕСТЬ NULL
				И НАЧАЛОПЕРИОДА(ЕСТЬNULL(вт_ПеремещенияПоПериодам.Месяц, втСвернутая.ПлановаяДатаЗапуска), МЕСЯЦ) >= НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				И втСвернутая.ДатаПланирования > ЕСТЬNULL(втСвернутая.ДатаПоследнегоАборта, ДАТАВРЕМЯ(1, 1, 1))
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ФактОтёлБрак,
	ЕСТЬNULL(втСвернутая.АбортСОткрытойЛактацией, ЛОЖЬ) КАК АбортСОткрытойЛактацией,
	ВЫБОР
		КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(вт_ПеремещенияПоПериодам.Месяц, втСвернутая.ПлановаяДатаЗапуска), МЕСЯЦ) >= НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаВыбраковки, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
			ТОГДА ""Брак""
		КОГДА вт_ПеремещенияПоПериодам.Месяц > НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
				ИЛИ вт_ПеремещенияПоПериодам.Месяц = НАЧАЛОПЕРИОДА(ЕСТЬNULL(втСвернутая.ДатаПервогоОтела, ДАТАВРЕМЯ(3000, 1, 1)), МЕСЯЦ)
					И ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) > 1
			ТОГДА ""Корова""
		ИНАЧЕ ""Тёлка""
	КОНЕЦ КАК ПроизводственнаяГруппа,
	ЕСТЬNULL(втСвернутая.КоличествоОтелов, 0) КАК КоличествоОтелов,
	втСвернутая.ДатаПоследнегоАборта КАК ДатаПоследнегоАборта,
	втСвернутая.ДатаПланирования КАК ДатаПланирования,
	вт_ПеремещенияПоПериодам.Ферма КАК Ферма
ИЗ
